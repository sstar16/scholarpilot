# ===========================================
# URIP - Universal Research Intelligence Platform
# 环境变量配置示例，复制为 .env 后填入实际值
# ===========================================

# 数据库
POSTGRES_DB=urip
POSTGRES_USER=urip
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://urip:change_me_strong_password@postgres:5432/urip

# Redis
REDIS_URL=redis://redis:6379/0

# JWT 认证
SECRET_KEY=change_me_to_a_very_long_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 应用设置
APP_ENV=production
DEBUG=false

# LLM 提供商（用户在界面配置，这里是默认值）
OLLAMA_HOST=http://host.docker.internal:11434

# 文件存储路径（容器内路径）
PDF_STORAGE_PATH=/app/data/pdfs
EXPORT_PATH=/app/data/exports

# Unpaywall（用于获取开放获取PDF，填入联系邮箱即可）
UNPAYWALL_EMAIL=your_email@example.com

# Lens.org 专利 API Token（免费，覆盖CN/US/EP/WO等90+国家专利）
# 注册：https://www.lens.org/lens/user/subscriptions → 申请 Scholarly API
# 不填则跳过 Lens.org 数据源，只用 USPTO
LENS_API_TOKEN=

# 前端 API 地址（开发用）
VITE_API_BASE_URL=http://localhost:8000
