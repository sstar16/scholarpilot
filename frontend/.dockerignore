# 关键：node_modules 不能进 build context
# Dockerfile builder 阶段会自己 npm install 干净版本
node_modules/

# 本地 vite build 产物 — 容器内 npm run build 会重新生成
dist/
.vite/

# Vite cache
.cache/

# 本地工具状态
.omc/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 文档不进 image
*.md

# 测试 / 配置（builder 阶段也不需要）
coverage/
.nyc_output/
